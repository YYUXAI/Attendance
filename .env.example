TELEGRAM_BOT_TOKEN=your_bot_token_here
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=attendance_bd
DB_USER=postgres
DB_PASSWORD=your_db_password

# 打卡截图 AI（智谱 GLM 视觉，国内 open.bigmodel.cn）
CHECKIN_AI_ENABLED=true
CHECKIN_AI_EXTRACT_BACKEND=zhipu
CHECKIN_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
CHECKIN_AI_API_KEY=your_zhipu_api_key
CHECKIN_AI_MODEL=glm-4.6v

CHECKIN_AI_MODE=required
CHECKIN_AI_MAX_CLOCK_SKEW_MINUTES=30
CHECKIN_AI_TIMEOUT_SECONDS=120
CHECKIN_AI_TRUST_SENDER_WHEN_NAME_UNREADABLE=false
CHECKIN_AI_NAME_VERIFY=vision
CHECKIN_AI_CLOCK_FALLBACK_SEND_TIME=false

# HTTP / 班次 Web App
DAILY_ATTENDANCE_REPORT_API_ENABLED=true
DAILY_ATTENDANCE_REPORT_API_HOST=127.0.0.1
DAILY_ATTENDANCE_REPORT_API_PORT=8787
DAILY_ATTENDANCE_REPORT_API_TOKEN=change-me-to-a-random-secret

SHIFT_WEB_ENABLED=true
SHIFT_WEB_APP_PUBLIC_URL=https://your-domain.example.com
SHIFT_WEB_TIMEZONE=Asia/Shanghai
SHIFT_WEB_BROWSER_DEV=false

# Google Sheets 排班表同步（可选）
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_GID=
GOOGLE_SHEETS_CREDENTIALS_JSON=secrets/google_service_account.json
GOOGLE_SHEETS_SYNC_INTERVAL_SECONDS=3600
GOOGLE_SHEETS_YEAR_MONTH=2026-06
